<!DOCTYPE html>
<html>
<head>
    <title>Expt 05</title>
</head>
<body>
<h2>GET vs POST Methods</h2>

<form action="methods" method="get">
    Name: <input type="text" name="name"><br><br>
    Email: <input type="email" name="email"><br><br>
    <input type="submit" value="Submit using GET">
</form>

<br><hr><br>

<form action="methods" method="post">
    Name: <input type="text" name="name"><br><br>
    Email: <input type="email" name="email"><br><br>
    <input type="submit" value="Submit using POST">
</form>
</body>
</html>
